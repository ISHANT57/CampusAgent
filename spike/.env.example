# M0 spike credentials. Copy to `.env` and fill in.
# NEVER commit .env — it is gitignored at the repo root.

# ---------------------------------------------------------------------------
# OpenRouter — https://openrouter.ai/keys
# Use a NEW key, not Project 1's. The spike will burn daily request caps, and
# you want to revoke P2 without touching P1's chat.
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=

# Comma-separated. Verify each is currently free AND lists tool-call support
# at https://openrouter.ai/models. Pick DIFFERENT model families — two Llama
# derivatives fail the same way, which tells you nothing about fallback.
OPENROUTER_MODELS=openai/gpt-oss-20b:free

# Pin the upstream provider so we measure a model, not a lottery. OpenRouter
# routes the same model name across several upstream hosts with different
# hardware and quantization; unpinned results are not reproducible next week.
# Leave blank to allow routing (and record that you did).
OPENROUTER_PIN_PROVIDER=
OPENROUTER_ALLOW_FALLBACKS=false

# Optional attribution headers OpenRouter uses for its leaderboards.
OPENROUTER_APP_TITLE=CampusBrain Agent M0 Spike
OPENROUTER_APP_URL=https://github.com/ISHANT57/CampusBrain

# ---------------------------------------------------------------------------
# Gemini — https://aistudio.google.com/apikey
# MUST be a different key from Project 1's. P1 calls Gemini for embeddings on
# every document upload; if this spike exhausts a shared quota, P1's ingestion
# pipeline dies with it.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Experiment settings
# ---------------------------------------------------------------------------
# Trials per case. Never judge a model on one sample — temperature=0 is not
# determinism (see ROADMAP Phase 1 / M0 theory §3.3).
TRIALS=5

# Seconds to sleep between calls. Free tiers throttle hard; this is the
# difference between a clean run and a wall of 429s.
SLEEP_BETWEEN_CALLS=4.0

REQUEST_TIMEOUT=90.0
MAX_TOKENS=512
