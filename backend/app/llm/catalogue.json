{
  "_about": [
    "Provider definitions as DATA, not code.",
    "",
    "Eight providers, three wire formats. Adding Together, Fireworks, DeepSeek or",
    "Cerebras is one entry here. Adding a genuinely different protocol (Cohere's",
    "native API, say) needs a new adapter — that is the honest boundary of",
    "'configuration, not code': config covers new VENDORS, not new PROTOCOLS.",
    "",
    "supports_tools is MANDATORY per model. M0/E2 found models that accept a",
    "`tools` parameter and silently ignore it; the agent then appears to refuse",
    "every task with no error anywhere. Models without it are never offered.",
    "",
    "blurb is shown in the UI and must be HONEST about limits. A user who picks",
    "OpenRouter expecting unlimited use will hit its cap in a few runs and",
    "conclude the app is broken."
  ],

  "providers": {
    "gemini": {
      "adapter": "gemini",
      "label": "Gemini",
      "blurb": "Generous free tier, fast. Recommended.",
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "auth": "header:x-goog-api-key",
      "requires_key": true,
      "allows_custom_base_url": false,
      "keys_url": "https://aistudio.google.com/apikey",
      "default_model": "gemini-3.1-flash-lite",
      "models": [
        {"id": "gemini-3.1-flash-lite", "label": "3.1 Flash Lite", "supports_tools": true,
