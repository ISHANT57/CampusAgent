        {"id": "gemini-2.5-flash", "label": "2.5 Flash", "supports_tools": true,
         "notes": "M0: 100% format and selection, but on a 13-call sample"},
        {"id": "gemini-3.5-flash", "label": "3.5 Flash", "supports_tools": true},
        {"id": "gemini-flash-lite-latest", "label": "Flash Lite (latest)", "supports_tools": true}
      ]
    },

