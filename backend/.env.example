# CampusBrain Agent — backend configuration.
# Copy to `.env` and fill in. `.env` is gitignored; this file is committed.
#
# Every variable without a default is REQUIRED and the app refuses to start
# without it (M2). Failing at startup beats discovering a missing key at step 7
# of a run, six LLM calls in.

# ---------------------------------------------------------------------------
# Database — Neon Postgres. MUST be a different database from Project 1's.
# Two services, two datastores; sharing one would be the first crack in the
# service boundary this project exists to maintain.
# ---------------------------------------------------------------------------
# Scheme is `postgresql+psycopg://` (psycopg3), NOT `+psycopg2`.
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# ---------------------------------------------------------------------------
# LLM providers. Order and model ids are frozen by the M0 evaluation —
# see spike/PROVIDER_EVALUATION.md before changing either.
# ---------------------------------------------------------------------------
LLM_PRIMARY_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=openrouter

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
# Pin the upstream host. OpenRouter routes one model name across several
# backends with different quantisations; unpinned, reliability numbers describe
# the routing lottery rather than the model.
OPENROUTER_ALLOW_FALLBACKS=false

# ---------------------------------------------------------------------------
# Project 1 — the Knowledge Service. Consumed over HTTP only.
# P2 never touches P1's Postgres, Qdrant, or object storage.
#
# REQUIRED, with no default: a default would hardcode a deployment target.
# Switching between local / staging / production must be a config change only.
#   production  https://<your-app>.onrender.com
#   local       http://localhost:8000
#
# KNOWLEDGE_BASE_API_KEY must match SERVICE_API_KEY in Project 1's environment
# (P1-CHANGE-1, see INTEGRATION_CONTRACT.md).
# ---------------------------------------------------------------------------
KNOWLEDGE_BASE_URL=https://your-project1-backend.onrender.com
KNOWLEDGE_BASE_API_KEY=
# 30s + one retry. Render free tier cold-starts take ~50s after idle.
KNOWLEDGE_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# Tools
# ---------------------------------------------------------------------------
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# Run budget (M19). Defaults are calibrated from M0's measured token and
# latency profile, not guessed — see PROVIDER_EVALUATION.md.
# Agent cost grows super-linearly with step count: the trace AND the tool
# schemas are re-sent on every turn.
# ---------------------------------------------------------------------------
MAX_STEPS=15
MAX_TOKENS_PER_RUN=120000
MAX_WALL_CLOCK_SECONDS=300
MAX_CALLS_PER_TOOL=4

# ---------------------------------------------------------------------------
# Tenancy. Single-tenant for now; `tenant_id` is carried through every table
# and every query from M4 so that adding multi-tenancy later changes only
# resolve_tenant(), not the queries. Project 1 put its equivalent constant at
# the endpoint instead, which is why it cannot serve a second institution.
# ---------------------------------------------------------------------------
DEFAULT_TENANT_ID=1

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=*
LOG_LEVEL=INFO
